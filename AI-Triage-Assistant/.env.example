# Copy this file to .env and fill in your real values.
# .env is already in .gitignore - never commit it.

# --- Option A: local dev, read endpoint/key directly from env vars ---
AZURE_AI_ENDPOINT=
AZURE_AI_KEY=
AZURE_AI_MODEL_NAME=

# --- Option B: production pattern, read secrets from Key Vault instead ---
# If this is set, config.py ignores AZURE_AI_KEY above and pulls the key
# from Key Vault using your logged-in Azure identity (az login / OIDC).
AZURE_KEY_VAULT_URL=

# Set to "true" to run without calling Azure at all - useful before
# sandbox access is confirmed, or for quick local testing.
TRIAGE_MOCK_MODE=true
